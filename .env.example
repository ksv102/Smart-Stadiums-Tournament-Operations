# Copy this file to .env and fill in your key.
# ORION runs fine without a key (falls back to deterministic templated
# explanations) — the key only upgrades the natural-language narration.
ANTHROPIC_API_KEY=
PORT=3000

# Optional: if set, all POST/write endpoints require a matching x-api-key
# header. Left unset, the server runs in open demo mode (reads and writes
# both open) and logs a warning at boot.
ORION_API_KEY=
